#include <stdio.h>
#include <string.h>

int main() {
    char str[100];
    int i, len;

    printf("Enter string: ");
    scanf("%s", str);

    len = strlen(str);

    int left = 0, right = 0;

    // Count left zeros
    for(i = 0; str[i] == '0'; i++)
        left++;

    // Count right zeros
    for(i = len-1; str[i] == '0'; i--)
        right++;

    // Check middle is only 1s
    int valid = 1;
    for(i = left; i < len-right; i++) {
        if(str[i] != '1') {
            valid = 0;
            break;
        }
    }

    if(left == right && valid)
        printf("Accepted\n");
    else
        printf("Rejected\n");

    return 0;
}
